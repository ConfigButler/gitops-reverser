apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
spec:
  interval: 5s
  timeout: 2m
  path: {{ .Path }}
  prune: {{ .Prune }}
  wait: {{ .Wait }}
  sourceRef:
    kind: GitRepository
    name: {{ .SourceName }}
{{- if .DependsOn }}
  dependsOn:
    - name: {{ .DependsOn }}
{{- end }}
