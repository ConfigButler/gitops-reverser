apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
spec:
  # Suspended so the helm-controller leaves the object inert: we are proving the
  # mirror/edit pipeline treats a higher-level KRM document like any other, not
  # exercising Flux itself. The referenced source need not exist.
  suspend: true
  interval: 30m
  chart:
    spec:
      chart: podinfo
      version: "{{ .Version }}"
      sourceRef:
        kind: HelmRepository
        name: podinfo
        namespace: {{ .Namespace }}
