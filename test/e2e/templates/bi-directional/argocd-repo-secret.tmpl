apiVersion: v1
kind: Secret
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
  labels:
    # Argo CD discovers repository credentials by this label, not by name.
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  type: git
  url: {{ .RepoURL }}
  username: {{ .Username }}
  password: {{ .Password }}
